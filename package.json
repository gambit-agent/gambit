{
  "name": "gambit",
  "version": "0.12.0",
  "description": "TUI coding agent CLI built with Bun, TypeScript, and OpenTUI.",
  "module": "src/index.tsx",
  "bin": {
    "gambit": "src/gambit.tsx"
  },
  "type": "module",
  "license": "MIT",
  "author": "Sergio Masellis <sergio@sergiomasellis.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gambit-agent/gambit.git"
  },
  "bugs": {
    "url": "https://github.com/gambit-agent/gambit/issues"
  },
  "homepage": "https://github.com/gambit-agent/gambit#readme",
  "keywords": [
    "cli",
    "tui",
    "ai",
    "agent",
    "coding",
    "openrouter",
    "mcp",
    "bun",
    "typescript",
    "opentui"
  ],
  "engines": {
    "bun": ">=1.2.20"
  },
  "files": [
    "src",
    "install",
    "install.sh",
    "install.ps1",
    "install.cmd",
    "AGENTS.md",
    "README.md",
    "INSTALL.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "bun run tsc --noEmit",
    "build": "bun run typecheck",
    "compile": "bun build --compile --outfile=gambit src/gambit.tsx",
    "test": "bun test",
    "dev": "bun run src/index.tsx",
    "start": "bun run src/gambit.tsx",
    "link-local": "bun link",
    "install-local": "bun run compile && ./gambit install",
    "release:check": "bun run typecheck && bun test",
    "prepublishOnly": "bun run release:check"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ai-sdk/provider": "^4.0.0",
    "@ai-sdk/provider-utils": "^5.0.1",
    "@modelcontextprotocol/client": "^2.0.0-alpha.3",
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "@opentui/core": "0.4.2",
    "@opentui/react": "0.4.2",
    "@types/node": "^26.0.1",
    "acorn": "^8.17.0",
    "ai": "^7.0.4",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  }
}
